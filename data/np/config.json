{
  "schema_version": 1,
  "description": "Net Pressure (TP) pipeline config. Per-protocol source paths for the daily flow components. v1 supports HYPE; AAVE/SKY/LIT will be added as their on-chain adapters land.",
  "notes": [
    "Net Pressure = (Unlocks + Treasury Sells) − (Buybacks + Burns + Treasury accumulation + Net staking lockups)",
    "Components without an on-chain source are computed as 0 with verification: 'n/a' — the formula is correct, the gap is documented.",
    "Treasury accumulation is intentionally 0 for HYPE: the AF is the buyback wallet (already counted as buybacks), not a separate treasury wallet. Counting both would double-count."
  ],
  "rollup_windows": [
    { "key": "24h",  "days": 1   },
    { "key": "7d",   "days": 7   },
    { "key": "30d",  "days": 30  },
    { "key": "90d",  "days": 90  }
  ],
  "protocols": {
    "hyperliquid": {
      "slug": "hyperliquid",
      "name": "Hyperliquid",
      "symbol": "HYPE",
      "config_symbol": "HYPE",
      "tokenomics_module": "scripts/onchain/hype/tokenomics.js",
      "sources": {
        "unlocks": {
          "type": "deterministic_schedule",
          "module": "scripts/onchain/hype/tokenomics.js",
          "verification": "onchain_equivalent",
          "sell_probability_by_recipient": {
            "team": 0.10,
            "foundation": 0.40,
            "airdrop": 0.20
          },
          "note": "TP weights scheduled unlocks by sell-probability (team mostly re-stakes). HM uses gross. future_emissions is tagged foundation=0.40 since community rewards sell more than pure foundation treasury."
        },
        "buybacks": {
          "type": "daily_series",
          "path": "data/onchain/hype-af/buybacks.json",
          "amount_field": "amount_tokens",
          "verification": "onchain"
        },
        "burns": {
          "type": "none",
          "verification": "n/a",
          "note": "HYPE does not burn"
        },
        "treasury_accumulation": {
          "type": "none",
          "verification": "n/a",
          "note": "AF is buyback_wallet not treasury_wallet — already counted as buybacks"
        },
        "treasury_sells": {
          "type": "none",
          "verification": "n/a",
          "note": "AF only buys"
        },
        "net_staking_lockups": {
          "type": "daily_snapshot_diff",
          "path": "data/onchain/hype/staking.json",
          "total_field": "total_staked_tokens",
          "verification": "onchain",
          "note": "Net daily lockup = today's total_staked_tokens − yesterday's (delegations minus undelegations). Recomputed at compute time from the snapshot column, since the stored delta_tokens field is corrupted by intra-day cron re-runs (each hourly write overwrites today's row, so its persisted delta becomes intra-day flux instead of day-over-day)."
        }
      },
      "static_reference_sources": {
        "circulating_supply": "data/onchain/hype/supply.json",
        "af_balance":          "data/onchain/hype-af/treasury.json",
        "total_staked":        "data/onchain/hype/staking.json"
      },
      "daily_price_path": "data/external/asxn/hype-price-daily.json"
    },
